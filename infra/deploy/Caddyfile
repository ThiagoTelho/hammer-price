# Hammer Price — proxy reverso com HTTPS AUTOMÁTICO (Let's Encrypt).
# O endereço do site vem do domínio em $DOMAIN; o Caddy emite/renova o certificado sozinho
# (precisa das portas 80 e 443 abertas). Encaminha o WebSocket do leilão (/ws) ao gateway e
# serve o build estático do frontend (SPA) para o resto.
{$DOMAIN} {
	encode gzip

	# WebSocket do jogo → gateway. O gateway lê os parâmetros da query (?player/?resume/&room),
	# então o prefixo /ws é ignorado por ele; o Caddy preserva a query e faz o upgrade sozinho.
	handle /ws* {
		reverse_proxy gateway:8080
	}

	# Frontend estático (single-page app): qualquer rota cai no index.html.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
