# Copie para `.env` e ajuste. NUNCA comite o `.env` real (ver .gitignore).
# No deploy AWS, cada EC2 tem seu próprio .env (use IPs PRIVADOS na comunicação interna).

# ----- PostgreSQL -----
PG_USER=hammer
PG_PASSWORD=changeme
# Porta publicada no host (mude p/ ex. 5433 se já houver um Postgres local na 5432).
PG_PORT=5432
PG_URL=postgres://hammer:changeme@postgres-primary:5432/hammerprice
PG_REPLICA_URL=postgres://hammer:changeme@postgres-replica:5432/hammerprice

# ----- Redis -----
REDIS_URL=redis://redis:6379

# ----- RabbitMQ -----
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# ----- gRPC (endereços dos serviços; em AWS use IP privado) -----
AUCTION_GRPC=auction-vault1:50051
WALLET_GRPC=wallet-shard1:50052

# ----- Gateway -----
GATEWAY_PORT=8080

# ----- Particionamento (definido por instância/container) -----
VAULT_ID=vault-1
SHARD_ID=shard-1

# ----- RNG -----
RNG_SEED=        # vazio = aleatório; defina para testes reproduzíveis

# ----- AWS (NÃO comitar valores reais) -----
# AWS_REGION=us-east-1
# Credenciais via perfil/instância (IAM role), não em arquivo.
